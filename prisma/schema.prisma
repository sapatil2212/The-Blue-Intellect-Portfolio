generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  name             String?
  password         String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  role             String         @default("Client")
  status           String         @default("PENDING")
  activityLogs     ActivityLog[]
  client           Client?
  comments         Comment[]
  employee         Employee?
  approvedLeaves   Leave[]        @relation("LeaveApprover")
  hostMeetings     Meeting[]      @relation("MeetingHost")
  notifications    Notification[]
  verifiedPayments Payment[]      @relation("PaymentVerifier")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
}

model Project {
  id             String     @id @default(uuid())
  title          String
  slug           String     @unique
  description    String     @db.Text
  categoryId     String
  thumbnail      String
  projectType    String
  websiteLink    String?
  sourceCodeLink String?
  pricing        String?
  featured       Boolean    @default(false)
  published      Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  clientId       String?
  endDate        DateTime?
  healthScore    Int        @default(100)
  startDate      DateTime?
  status         String     @default("PLANNING")
  comments       Comment[]
  invoices       Invoice[]
  media          Media[]
  category       Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  client         Client?    @relation(fields: [clientId], references: [id])
  tasks          Task[]
  team           Employee[] @relation("ProjectTeam")
  tags           Tag[]      @relation("ProjectToTag")

  @@index([categoryId], map: "Project_categoryId_fkey")
  @@index([clientId], map: "Project_clientId_fkey")
}

model Media {
  id        String   @id @default(uuid())
  url       String
  type      String
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId], map: "Media_projectId_fkey")
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[] @relation("ProjectToTag")
}

model Otp {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Employee {
  id               String       @id @default(uuid())
  userId           String       @unique
  employeeId       String       @unique
  department       String
  salary           Float        @default(0)
  joiningDate      DateTime     @default(now())
  skills           String?
  phone            String?
  emergencyContact String?
  managerId        String?
  attendance       Attendance[]
  manager          Employee?    @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  subordinates     Employee[]   @relation("EmployeeManager")
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads            Lead[]       @relation("LeadOwner")
  leaves           Leave[]
  standups         Standup[]
  tasks            Task[]
  projects         Project[]    @relation("ProjectTeam")

  @@index([managerId], map: "Employee_managerId_fkey")
}

model Client {
  id                 String    @id @default(uuid())
  userId             String    @unique
  companyName        String?
  phone              String?
  whatsapp           String?
  website            String?
  servicesInterested String?
  estimatedBudget    String?
  deadline           String?
  referenceLinks     String?
  brandDetails       String?
  socialLinks        String?
  onboardingStep     Int       @default(1)
  verificationStatus String    @default("PENDING")
  approvedBy         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices           Invoice[]
  projects           Project[]
}

model Lead {
  id                 String           @id @default(uuid())
  clientName         String
  companyName        String?
  phone              String?
  whatsapp           String?
  email              String?
  source             String           @default("Direct")
  assignedEmployeeId String?
  estimatedBudget    Float            @default(0)
  servicesInterested String?
  priority           String           @default("MEDIUM")
  status             String           @default("NEW")
  notes              String?          @db.Text
  followUpDate       DateTime?
  lastInteraction    DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  interactions       InteractionLog[]
  assignedEmployee   Employee?        @relation("LeadOwner", fields: [assignedEmployeeId], references: [id])

  @@index([assignedEmployeeId], map: "Lead_assignedEmployeeId_fkey")
}

model InteractionLog {
  id         String   @id @default(uuid())
  leadId     String
  date       DateTime @default(now())
  type       String
  content    String   @db.Text
  employeeId String?
  createdAt  DateTime @default(now())
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId], map: "InteractionLog_leadId_fkey")
}

model Task {
  id                String           @id @default(uuid())
  projectId         String
  title             String
  description       String?          @db.Text
  status            String           @default("TODO")
  priority          String           @default("MEDIUM")
  deadline          DateTime?
  assignedToId      String?
  creatorId         String?
  recurring         Boolean          @default(false)
  recurrencePattern String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  comments          Comment[]
  subtasks          Subtask[]
  assignedTo        Employee?        @relation(fields: [assignedToId], references: [id])
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  predecedents      TaskDependency[] @relation("TaskPredecessor")
  dependencies      TaskDependency[] @relation("TaskSuccessor")

  @@index([assignedToId], map: "Task_assignedToId_fkey")
  @@index([projectId], map: "Task_projectId_fkey")
}

model Subtask {
  id          String   @id @default(uuid())
  taskId      String
  title       String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId], map: "Subtask_taskId_fkey")
}

model TaskDependency {
  id            String @id @default(uuid())
  taskId        String
  dependsOnId   String
  dependsOnTask Task   @relation("TaskPredecessor", fields: [dependsOnId], references: [id], onDelete: Cascade)
  task          Task   @relation("TaskSuccessor", fields: [taskId], references: [id], onDelete: Cascade)

  @@index([dependsOnId], map: "TaskDependency_dependsOnId_fkey")
  @@index([taskId], map: "TaskDependency_taskId_fkey")
}

model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  taskId    String?
  projectId String?
  userId    String
  createdAt DateTime @default(now())
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId], map: "Comment_projectId_fkey")
  @@index([taskId], map: "Comment_taskId_fkey")
  @@index([userId], map: "Comment_userId_fkey")
}

model Invoice {
  id               String    @id @default(uuid())
  invoiceNumber    String    @unique
  clientId         String
  projectId        String?
  amount           Float     @default(0)
  taxAmount        Float     @default(0)
  commissionAmount Float     @default(0)
  discount         Float     @default(0)
  status           String    @default("PENDING")
  paymentMethod    String?
  dueDate          DateTime?
  invoiceDate      DateTime  @default(now())
  fileUrl          String?
  notes            String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project          Project?  @relation(fields: [projectId], references: [id])
  payments         Payment[]

  @@index([clientId], map: "Invoice_clientId_fkey")
  @@index([projectId], map: "Invoice_projectId_fkey")
}

model Payment {
  id              String   @id @default(uuid())
  invoiceId       String
  amountPaid      Float    @default(0)
  paymentDate     DateTime @default(now())
  paymentMethod   String
  referenceNumber String?
  screenshotUrl   String?
  status          String   @default("PENDING")
  verifiedById    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  verifiedBy      User?    @relation("PaymentVerifier", fields: [verifiedById], references: [id])

  @@index([invoiceId], map: "Payment_invoiceId_fkey")
  @@index([verifiedById], map: "Payment_verifiedById_fkey")
}

model Attendance {
  id         String    @id @default(uuid())
  employeeId String
  date       DateTime  @default(now())
  clockIn    DateTime  @default(now())
  clockOut   DateTime?
  status     String    @default("PRESENT")
  notes      String?
  createdAt  DateTime  @default(now())
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId], map: "Attendance_employeeId_fkey")
}

model Leave {
  id           String   @id @default(uuid())
  employeeId   String
  leaveType    String
  startDate    DateTime
  endDate      DateTime
  reason       String   @db.Text
  status       String   @default("PENDING")
  approvedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  approvedBy   User?    @relation("LeaveApprover", fields: [approvedById], references: [id])
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([approvedById], map: "Leave_approvedById_fkey")
  @@index([employeeId], map: "Leave_employeeId_fkey")
}

model Standup {
  id                 String   @id @default(uuid())
  employeeId         String
  date               DateTime @default(now())
  completedYesterday String   @db.Text
  planningToday      String   @db.Text
  blockers           String?  @db.Text
  productivityScore  Int      @default(100)
  createdAt          DateTime @default(now())
  employee           Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId], map: "Standup_employeeId_fkey")
}

model Meeting {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  startTime   DateTime
  endTime     DateTime
  type        String   @default("INTERNAL")
  link        String?
  hostId      String
  attendees   String?
  createdAt   DateTime @default(now())
  host        User     @relation("MeetingHost", fields: [hostId], references: [id], onDelete: Cascade)

  @@index([hostId], map: "Meeting_hostId_fkey")
}

model Document {
  id          String   @id @default(uuid())
  name        String
  fileUrl     String
  fileType    String
  folder      String   @default("General")
  tag         String?
  accessLevel String   @default("PUBLIC")
  ownerId     String?
  sizeBytes   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String   @db.Text
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  priority  String   @default("LOW")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Notification_userId_fkey")
}

model WhatsAppQueue {
  id             String    @id @default(uuid())
  recipientPhone String
  templateName   String
  variables      String    @db.Text
  status         String    @default("PENDING")
  scheduledFor   DateTime  @default(now())
  processedAt    DateTime?
  createdAt      DateTime  @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String?  @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "ActivityLog_userId_fkey")
}

model ChatChannel {
  id        String        @id @default(uuid())
  name      String        @unique
  isPrivate Boolean       @default(false)
  createdAt DateTime      @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id          String      @id @default(uuid())
  channelId   String
  senderEmail String
  senderName  String
  content     String      @db.Text
  createdAt   DateTime    @default(now())
  channel     ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId], map: "ChatMessage_channelId_fkey")
}
